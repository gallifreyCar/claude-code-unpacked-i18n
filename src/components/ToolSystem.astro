---
export interface Props {
  lang: 'en' | 'zh' | 'ja';
}

import { ui } from '../i18n/ui';
import { toolCategories } from '../data/tools';

const { lang } = Astro.props;

const categoryColors: Record<string, string> = {
  'file': 'border-blue-500/30 hover:border-blue-500/60',
  'execution': 'border-red-500/30 hover:border-red-500/60',
  'search': 'border-cyan-500/30 hover:border-cyan-500/60',
  'agents': 'border-purple-500/30 hover:border-purple-500/60',
  'planning': 'border-orange-500/30 hover:border-orange-500/60',
  'mcp': 'border-green-500/30 hover:border-green-500/60',
  'system': 'border-yellow-500/30 hover:border-yellow-500/60',
  'experimental': 'border-pink-500/30 hover:border-pink-500/60',
};
---

<section id="tools" class="py-20 px-4">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <span class="inline-block text-cc-purple font-mono text-sm mb-4">03</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        {ui[lang]['section.tools.title']}
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto">
        {ui[lang]['section.tools.subtitle']}
      </p>
    </div>

    <!-- Tool Categories -->
    <div class="space-y-8">
      {toolCategories.map((category) => (
        <div class="bg-cc-dark rounded-2xl border border-gray-700/50 overflow-hidden">
          <!-- Category Header -->
          <div class="flex items-center justify-between p-4 bg-cc-darker/50 border-b border-gray-700/50">
            <h3 class="text-lg font-semibold text-white">
              {category.name[lang]}
            </h3>
            <span class="text-sm text-gray-400">
              {category.tools.length} {lang === 'en' ? 'tools' : lang === 'zh' ? '工具' : 'ツール'}
            </span>
          </div>

          <!-- Tools Grid -->
          <div class="p-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {category.tools.map((tool) => (
              <button
                class="tool-card group p-3 rounded-xl border transition-all text-left {categoryColors[category.id] || 'border-gray-700/30 hover:border-gray-700/60'}"
                data-tool={tool.name}
              >
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="font-mono text-sm text-white group-hover:text-cc-cyan transition-colors">
                      {tool.name}
                    </div>
                    <div class="text-xs text-gray-400 mt-1 line-clamp-2">
                      {tool.description[lang]}
                    </div>
                  </div>
                  {tool.featureGated && (
                    <span class="text-xs text-yellow-500 ml-2">🔒</span>
                  )}
                </div>
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-gray-500 text-sm mt-6">
      {ui[lang]['label.clickToSee']}
    </p>
  </div>
</section>
