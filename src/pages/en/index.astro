---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Hero from '../../components/Hero.astro';
import AgentLoop from '../../components/AgentLoop.astro';
import ArchitectureExplorer from '../../components/ArchitectureExplorer.astro';
import ToolSystem from '../../components/ToolSystem.astro';
import CommandCatalog from '../../components/CommandCatalog.astro';
import HiddenFeatures from '../../components/HiddenFeatures.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en';
---

<Layout title="Claude Code Unpacked" lang={lang}>
  <Navigation lang={lang} />
  <main>
    <Hero lang={lang} />
    <AgentLoop lang={lang} />
    <ArchitectureExplorer lang={lang} />
    <ToolSystem lang={lang} />
    <CommandCatalog lang={lang} />
    <HiddenFeatures lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
